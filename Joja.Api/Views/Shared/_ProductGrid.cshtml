@model IEnumerable<Joja.Api.Models.Product>

@foreach (var product in Model)
{
    <a asp-controller="Home" asp-action="Details" asp-route-id="@product.Id" class="text-decoration-none text-dark" style="display: block;">
        <div class="product-card position-relative text-center" style="background: transparent; border: none;">
            
            @if (product.OriginalPrice.HasValue && product.OriginalPrice > product.Price)
            {
                var discount = Math.Round((decimal)((product.OriginalPrice.Value - product.Price) / product.OriginalPrice.Value * 100));
                <span class="discount-badge">خصم @discount%</span>
            }
            
            <img src="@product.MainImageUrl?.Replace("/upload/", "/upload/w_400,q_auto,f_auto/")" alt="@product.Name" class="img-fluid rounded mb-3" style="width: 100%; height: 300px; object-fit: cover;" />
            
            <h5 class="product-title" style="font-size: 1.1rem; font-weight: 600;">@product.Name</h5>
            
            <div class="product-price mt-2" style="font-family: 'Inter', sans-serif;">
                @if (product.OriginalPrice.HasValue && product.OriginalPrice > product.Price)
                {
                    <span class="old-price">@product.OriginalPrice.Value EGP</span>
                    <span class="new-price">@product.Price EGP</span>
                }
                else
                {
                    <span class="new-price" style="color: #666; font-weight: 600;">@product.Price.ToString("0.00") EGP</span>
                }
            </div>
        </div>
    </a>
}
