@using Joja.Api.Data
@using Microsoft.EntityFrameworkCore
@inject ApplicationDbContext _context
@inject Joja.Api.Services.ILocalizationService _localizationService
@{
    // قراءة الكوكي مباشرةً - يشتغل على كل الصفحات
    var currentLang = Context.Request.Cookies["UserLanguage"] ?? "en";
    // Force LTR for both languages to keep identical layout
    var direction = "ltr";
    
    // Fetch Settings
    var appSettings = await _context.AppSettings.FirstOrDefaultAsync();
    var fbLink = appSettings?.FacebookLink ?? "#";
    var instaLink = appSettings?.InstagramLink ?? "#";
    
    // Fetch Categories for Nav
    var navCategories = await _context.Categories.AsNoTracking().ToListAsync();
    _localizationService.GetLocalizedCategories(navCategories, currentLang);
}
<!DOCTYPE html>
<html lang="@currentLang" dir="@direction">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - JOJA</title>

    <!-- Open Graph SEO Meta Tags -->
    @if (ViewBag.OgTitle != null)
    {
        <meta property="og:title" content="@ViewBag.OgTitle" />
        <meta property="og:description" content="@ViewBag.OgDescription" />
        <meta property="og:image" content="@ViewBag.OgImage" />
        <meta property="og:type" content="product" />
        <meta name="twitter:card" content="summary_large_image">
    }
    else
    {
        <meta property="og:title" content="JOJA - Your Beauty Store" />
        <meta property="og:description" content="Discover the best skincare and haircare products at JOJA." />
        <meta property="og:type" content="website" />
    }
    
    <!-- Performance & SEO -->
    <meta name="description" content="JOJA - Natural skincare products for your beauty" />
    <meta name="theme-color" content="#F3E9E2" />
    
    @{
        var pixelId = appSettings?.PixelId;
    }
    @if (!string.IsNullOrEmpty(pixelId))
    {
        <!-- Meta Pixel Code -->
        <script>
        !function(f,b,e,v,n,t,s)
        {if(f.fbq)return;n=f.fbq=function(){n.callMethod?
        n.callMethod.apply(n,arguments):n.queue.push(arguments)};
        if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
        n.queue=[];t=b.createElement(e);t.async=!0;
        t.src=v;s=b.getElementsByTagName(e)[0];
        s.parentNode.insertBefore(t,s)}(window, document,'script',
        'https://connect.facebook.net/en_US/fbevents.js');
        fbq('init', '@pixelId');
        fbq('track', 'PageView');
        </script>
        <noscript><img height="1" width="1" style="display:none"
        src="https://www.facebook.com/tr?id=@pixelId&ev=PageView&noscript=1"
        /></noscript>
        <!-- End Meta Pixel Code -->
    }
    
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    @if (currentLang == "ar") {
        <link rel="stylesheet" href="~/css/rtl.css" asp-append-version="true" />
    }
    <link rel="icon" type="image/png" href="~/images/favicon.png" sizes="32x32" />
    <link rel="icon" type="image/png" href="~/images/favicon.png" sizes="192x192" />
    <link rel="apple-touch-icon" href="~/images/favicon.png" />
    <!-- Add FontAwesome for icons (non-blocking) -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" media="print" onload="this.media='all'">
    <noscript><link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css"></noscript>
</head>
<body>
    <header>
        <!-- Top Bar (Old) -->
        @if (!string.IsNullOrEmpty(appSettings?.TopBarText))
        {
             <div class="top-bar" style="background-color: #B7477E; color: #ffffff; text-align: center; padding: 8px 0; font-size: 0.9rem; font-weight: 500;">
                 <div class="container">
                     @appSettings.TopBarText
                 </div>
             </div>
        }
        
        <!-- Dynamic Header Announcement -->
        @{
            var siteSettingHeader = _context.SiteSettings.FirstOrDefault();
            var headerText = siteSettingHeader?.HeaderAnnouncementText;
        }
        @if (!string.IsNullOrEmpty(headerText))
        {
            <div class="announcement-bar" style="background-color: #B7477E; color: #ffffff; text-align: center; padding: 8px 0; font-weight: bold; font-size: 0.9rem;">
                @headerText
            </div>
        }
        <nav class="navbar">
            <div class="container nav-container">
                <!-- Logo Left -->
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    <img src="~/images/logo.webp" alt="JOJA" class="logo-img" />
                </a>

                <!-- Nav Center -->
                <ul class="nav-links" id="navLinks">
                    <li><a asp-controller="Home" asp-action="Index">@_localizationService.GetUiText("NavHome", currentLang)</a></li>
                    <li><a href="/#shop-section">@_localizationService.GetUiText("NavShop", currentLang)</a></li>
                    @foreach (var cat in navCategories)
                    {
                        <li><a href="/?categoryId=@cat.Id#shop-section">@cat.Name</a></li>
                    }
                    <li><a href="#about-us">@_localizationService.GetUiText("NavAboutUs", currentLang)</a></li>
                </ul>

                <!-- Icons Right -->
                <div class="nav-icons d-flex align-items-center">
                    <!-- Language Switcher - Moved to front -->
                    <div class="language-switcher me-2 d-flex align-items-center">
                        @if (currentLang == "ar")
                        {
                            <a href="/Home/SetLanguage?culture=en-US&returnUrl=@System.Net.WebUtility.UrlEncode(Context.Request.Path)" class="btn rounded-pill px-2 py-1" style="border: 1px solid #B7477E; color: #B7477E; font-size: 0.8rem; font-weight: bold; text-decoration: none; transition: all 0.3s;" onmouseover="this.style.backgroundColor='#B7477E'; this.style.color='#fff';" onmouseout="this.style.backgroundColor='transparent'; this.style.color='#B7477E';">
                                <i class="fas fa-globe"></i> EN
                            </a>
                        }
                        else
                        {
                            <a href="/Home/SetLanguage?culture=ar-EG&returnUrl=@System.Net.WebUtility.UrlEncode(Context.Request.Path)" class="btn rounded-pill px-2 py-1" style="border: 1px solid #B7477E; color: #B7477E; font-size: 0.8rem; font-weight: bold; text-decoration: none; font-family: 'Tajawal', sans-serif; transition: all 0.3s;" onmouseover="this.style.backgroundColor='#B7477E'; this.style.color='#fff';" onmouseout="this.style.backgroundColor='transparent'; this.style.color='#B7477E';">
                                <i class="fas fa-globe"></i> AR
                            </a>
                        }
                    </div>
                    
                    <!-- Search Toggle (Desktop Only) -->
                    <div class="d-none d-md-flex align-items-center me-3 position-relative">
                        <button id="searchToggleBtn" style="background: none; border: none; color: #B7477E; cursor: pointer;">
                            <i class="fas fa-search" style="font-size: 1.2rem;"></i>
                        </button>
                        <form id="searchForm" asp-controller="Home" asp-action="Search" method="get" class="position-absolute" style="display: none; top: 100%; right: 0; margin-top: 10px; z-index: 1000; background: #fff; padding: 10px; border-radius: 8px; box-shadow: 0 4px 6px rgba(0,0,0,0.1); border: 1px solid #eee;">
                            <div class="d-flex align-items-center position-relative">
                                <input type="text" autocomplete="off" name="searchQuery" id="searchInput" value="@ViewBag.SearchQuery" placeholder="@(_localizationService.GetUiText("SearchProducts", currentLang) ?? "Search products...")" class="form-control rounded-pill" style="border: 1px solid #B7477E; padding: 6px 35px 6px 15px; width: 250px; font-size: 0.9rem;" />
                                <button type="submit" style="position: absolute; right: 10px; background: none; border: none; color: #B7477E; cursor: pointer;">
                                    <i class="fas fa-search"></i>
                                </button>
                            </div>
                            <div id="searchResults" class="position-absolute w-100 bg-white shadow rounded mt-1" style="display: none; max-height: 300px; overflow-y: auto; z-index: 1001; left: 0;"></div>
                        </form>
                    </div>

                    <a href="#" class="nav-link position-relative d-inline-block me-3" onclick="showWishlistModal(event)">
                        <i class="fas fa-heart" style="font-size: 1.2rem; color: #B7477E;"></i>
                        <span id="wishlist-badge" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="display: none;">
                            0
                        </span>
                    </a>
                    
                    <a href="#" class="nav-link position-relative d-inline-block" data-bs-toggle="offcanvas" data-bs-target="#cartOffcanvas" aria-controls="cartOffcanvas">
                        <i class="fas fa-shopping-cart" style="font-size: 1.2rem; color: #B7477E;"></i>
                        <span id="cart-badge" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
                            0
                        </span>
                    </a>

                    <!-- Mobile Menu Toggle - Moved inside icons for far-right positioning -->
                    <button class="mobile-menu-toggle ms-2" onclick="toggleMobileMenu()">
                        <i class="fas fa-bars"></i>
                    </button>
                    
                    <!-- Mobile Menu Backdrop -->
                    <div id="mobileBackdrop" class="mobile-menu-backdrop" onclick="toggleMobileMenu()"></div>
                    
                    @if (User.Identity.IsAuthenticated)
                    {
                        <ul class="navbar-nav ms-auto d-none d-md-flex" style="flex-direction: row; list-style: none; margin: 0; padding: 0; align-items: center; gap: 15px;">
                            <li class="nav-item">
                                <span class="nav-link text-success" style="font-weight: bold;">Welcome Admin 👑</span>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-warning" asp-controller="Auth" asp-action="ChangePassword" style="font-weight: bold;">Change Password</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-danger" asp-controller="Auth" asp-action="Logout" style="font-weight: bold;">Logout</a>
                            </li>
                        </ul>
                    }
                </div>
            </div>
        </nav>
    </header>

    <script>
        function toggleMobileMenu() {
            document.getElementById('navLinks').classList.toggle('active');
            document.getElementById('mobileBackdrop').classList.toggle('active');
            document.body.style.overflow = document.getElementById('navLinks').classList.contains('active') ? 'hidden' : '';
        }
        
        // Close mobile menu when clicking outside
        document.addEventListener('click', function(event) {
            const nav = document.getElementById('navLinks');
            const toggle = document.querySelector('.mobile-menu-toggle');
            if (nav && toggle && nav.classList.contains('active') && !nav.contains(event.target) && !toggle.contains(event.target)) {
                toggleMobileMenu();
            }
        });

        // Close mobile menu when a link inside is clicked
        document.querySelectorAll('.nav-links a').forEach(link => {
            link.addEventListener('click', () => {
                if (document.getElementById('navLinks').classList.contains('active')) {
                    toggleMobileMenu();
                }
            });
        });

        // Search Toggle Logic
        const searchToggleBtn = document.getElementById('searchToggleBtn');
        const searchForm = document.getElementById('searchForm');
        if (searchToggleBtn && searchForm) {
            searchToggleBtn.addEventListener('click', function(e) {
                e.stopPropagation();
                if (searchForm.style.display === 'none') {
                    searchForm.style.display = 'block';
                    document.getElementById('searchInput').focus();
                } else {
                    searchForm.style.display = 'none';
                }
            });
            document.addEventListener('click', function(e) {
                if (searchForm.style.display === 'block' && !searchForm.contains(e.target) && !searchToggleBtn.contains(e.target)) {
                    searchForm.style.display = 'none';
                }
            });
        }
    </script>

    <main role="main">
        @RenderBody()
    </main>

    <footer id="about-us">
        <style>
            footer, footer h3, footer p, footer .copyright { color: #ffffff !important; }
            footer a { color: #ffffff !important; transition: 0.3s; }
            footer a:hover { opacity: 0.8; }
        </style>
        @{
            var siteSettingFooter = _context.SiteSettings.FirstOrDefault();
            var footerText = siteSettingFooter?.FooterAboutText ?? "Natural skincare products formulated with care & science";
        }
        <div class="container">
            <div class="footer-grid">
                <div class="footer-col">
                    <h3>@_localizationService.GetUiText("AboutJoja", currentLang)</h3>
                    <p>@footerText</p>
                </div>
                <div class="footer-col">
                    <h3>@_localizationService.GetUiText("QuickLinks", currentLang)</h3>
                    <ul>
                        <li><a href="/#shop-section">@_localizationService.GetUiText("NavShop", currentLang)</a></li>
                        <li><a href="/#shop-section">@_localizationService.GetUiText("BestSellers", currentLang)</a></li>
                        <li><a href="#about-us">@_localizationService.GetUiText("NavContactUs", currentLang)</a></li>
                    </ul>
                </div>
                <div class="footer-col">
                    <h3>@_localizationService.GetUiText("FollowUs", currentLang)</h3>
                    <div class="social-links">
                        <a href="@fbLink" target="_blank"><i class="fab fa-facebook"></i></a>
                        <a href="@instaLink" target="_blank"><i class="fab fa-instagram"></i></a>
                        <a href="#"><i class="fab fa-tiktok"></i></a>
                    </div>
                    <div style="margin-top: 15px;">
                        <a asp-controller="Admin" asp-action="Index" style="font-size: 0.8rem; opacity: 0.7;">Admin Access</a>
                    </div>
                </div>
            </div>
            <div class="footer-contact-info" style="text-align: center; margin-top: 30px; padding-top: 20px; border-top: 1px solid rgba(255,255,255,0.1); font-size: 0.95rem;">
                @{
                    var contactEmail = siteSettingFooter?.ContactEmail ?? "joja.organic@gmail.com";
                    var whatsappNumFooter = siteSettingFooter?.WhatsAppNumber ?? "201090428764";
                }
                <a href="https://wa.me/@whatsappNumFooter" target="_blank" style="text-decoration: none;">
                    <i class="fab fa-whatsapp"></i> @whatsappNumFooter
                </a>
                <span style="margin: 0 10px; opacity: 0.8;">،</span>
                <a href="mailto:@contactEmail" style="text-decoration: none;">
                    <i class="fas fa-envelope"></i> @contactEmail
                </a>
            </div>
            <div class="copyright" style="margin-top: 15px;">
                &copy; 2026 JOJA Skincare. All rights reserved.
            </div>
        </div>
    </footer>

    <!-- Newsletter Modal -->
    <div id="newsletterModal" class="joja-modal">
        <div class="modal-content">
            <span class="close-modal" style="position:absolute; right:20px; top:10px; cursor:pointer; font-size:24px;">&times;</span>
            <h2 class="brand-font">Join the Club</h2>
            <p>Subscribe to get exclusive skincare tips and offers.</p>
            <input type="email" id="subscriberEmail" placeholder="Enter your email" />
            <button onclick="submitSubscription()" class="btn-joja-dark">Subscribe</button>
        </div>
    </div>

    @{
        var siteSetting = _context.SiteSettings.FirstOrDefault();
        var whatsappNum = siteSetting?.WhatsAppNumber ?? "201000000000"; 
    }
    <a href="https://wa.me/@whatsappNum" class="whatsapp-float" target="_blank" rel="noopener noreferrer">
        <i class="fab fa-whatsapp"></i>
    </a>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        // Modal Logic
        document.addEventListener("DOMContentLoaded", function() {
            // Show modal after 5 seconds if not seen before (and not subscribed)
            if (!localStorage.getItem('joja_popup_seen') && !localStorage.getItem('joja_subscribed')) {
                setTimeout(function() {
                    document.getElementById('newsletterModal').style.display = 'flex';
                }, 5000);
            }

            document.querySelector('.close-modal').onclick = function() {
                document.getElementById('newsletterModal').style.display = 'none';
                // Mark as seen so it doesn't show again
                localStorage.setItem('joja_popup_seen', 'true');
            }
        });

        function submitSubscription() {
            var email = document.getElementById('subscriberEmail').value;
            if(email) {
                fetch('/Home/SubscribeNewsletter', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: 'email=' + encodeURIComponent(email)
                })
                .then(response => response.json())
                .then(data => {
                    if(data.success) {
                        alert(data.message);
                        document.getElementById('newsletterModal').style.display = 'none';
                        localStorage.setItem('joja_subscribed', 'true');
                    }
                });
            }
        }
    </script>
    <script>
        // Analytics Logic
        document.addEventListener("DOMContentLoaded", function() {
            // Track Visit (Once per session)
            if (!sessionStorage.getItem('joja_visit_logged')) {
                fetch('https://ipapi.co/json/')
                    .then(response => response.json())
                    .then(data => {
                        logEvent('Visit', null, data.country_name, data.city);
                        sessionStorage.setItem('joja_visit_logged', 'true');
                    })
                    .catch(() => {
                        logEvent('Visit', null, 'Unknown', 'Unknown');
                        sessionStorage.setItem('joja_visit_logged', 'true');
                    });
            }
        });

        function logEvent(eventType, product = null, country = null, city = null) {
            fetch('/api/Analytics/LogEvent', {
                method: 'POST',
                headers: { 
                    'Content-Type': 'application/json' 
                },
                body: JSON.stringify({
                    eventType: eventType,
                    page: window.location.pathname,
                    product: product,
                    country: country || 'Unknown',
                    city: city || 'Unknown',
                    device: /Mobi|Android/i.test(navigator.userAgent) ? 'Mobile' : 'Desktop'
                })
            }).catch(e => console.error("Analytics Error:", e));
        }
    </script>
    <div class="offcanvas offcanvas-end shadow" tabindex="-1" id="cartOffcanvas" aria-labelledby="cartOffcanvasLabel">
        <!-- Content loaded dynamically via AJAX -->
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            var cartOffcanvasElement = document.getElementById('cartOffcanvas');
            if (cartOffcanvasElement) {
                cartOffcanvasElement.addEventListener('show.bs.offcanvas', function () {
                    fetch('/Cart/GetCartAjax')
                        .then(response => response.text())
                        .then(html => {
                            cartOffcanvasElement.innerHTML = html;
                        });
                });
            }

            // Live Search Autocomplete
            const searchInput = document.getElementById('searchInput');
            const searchResults = document.getElementById('searchResults');
            let timeoutId;

            if (searchInput && searchResults) {
                searchInput.addEventListener('input', function() {
                    clearTimeout(timeoutId);
                    const query = this.value.trim();

                    if (query.length < 2) {
                        searchResults.style.display = 'none';
                        return;
                    }

                    timeoutId = setTimeout(() => {
                        fetch(`/Home/SearchAjax?query=${encodeURIComponent(query)}`)
                            .then(res => res.json())
                            .then(data => {
                                if (data && data.length > 0) {
                                    searchResults.innerHTML = data.map(p => `
                                        <a href="/Home/Details/${p.id}" class="d-flex align-items-center p-2 text-decoration-none border-bottom" style="color: inherit;">
                                            <img src="${p.imageUrl}" alt="${p.name}" style="width: 40px; height: 40px; object-fit: cover; border-radius: 4px; margin-right: 10px;">
                                            <div>
                                                <div class="fw-bold" style="font-size: 0.9rem;">${p.name}</div>
                                                <div class="text-muted" style="font-size: 0.8rem;">${p.price} LE</div>
                                            </div>
                                        </a>
                                    `).join('');
                                    searchResults.style.display = 'block';
                                } else {
                                    searchResults.innerHTML = '<div class="p-3 text-muted text-center">No results found</div>';
                                    searchResults.style.display = 'block';
                                }
                            });
                    }, 300);
                });

                document.addEventListener('click', function(e) {
                    if (!searchInput.contains(e.target) && !searchResults.contains(e.target)) {
                        searchResults.style.display = 'none';
                    }
                });
            }
        });

        // Wishlist Logic
        function getWishlist() {
            let wl = localStorage.getItem('joja_wishlist');
            return wl ? JSON.parse(wl) : [];
        }
        function saveWishlist(wl) {
            localStorage.setItem('joja_wishlist', JSON.stringify(wl));
            updateWishlistBadge();
        }
        function updateWishlistBadge() {
            let wl = getWishlist();
            let badge = document.getElementById('wishlist-badge');
            if (badge) {
                if (wl.length > 0) {
                    badge.innerText = wl.length;
                    badge.style.display = 'inline-block';
                } else {
                    badge.style.display = 'none';
                }
            }
            // Update all hearts
            document.querySelectorAll('.wishlist-btn').forEach(btn => {
                let id = parseInt(btn.getAttribute('onclick').match(/\d+/)[0]);
                if (wl.includes(id)) {
                    btn.style.color = '#B7477E';
                } else {
                    btn.style.color = '#ccc';
                }
            });
        }
        function toggleWishlist(e, id, btn) {
            e.preventDefault();
            e.stopPropagation();
            let wl = getWishlist();
            if (wl.includes(id)) {
                wl = wl.filter(x => x !== id);
                btn.style.color = '#ccc';
                Swal.fire({ toast: true, position: 'bottom-end', showConfirmButton: false, timer: 2000, icon: 'info', title: 'Removed from wishlist' });
            } else {
                wl.push(id);
                btn.style.color = '#B7477E';
                Swal.fire({ toast: true, position: 'bottom-end', showConfirmButton: false, timer: 2000, icon: 'success', title: 'Added to wishlist ❤️' });
            }
            saveWishlist(wl);
        }
        function showWishlistModal(e) {
            e.preventDefault();
            let wl = getWishlist();
            if (wl.length === 0) {
                Swal.fire('Wishlist', 'Your wishlist is empty!', 'info');
            } else {
                Swal.fire('Wishlist', 'You have ' + wl.length + ' items in your wishlist. Go to the products to view them!', 'info');
                // In a full implementation, this could fetch products by ID and display them in a modal.
            }
        }
        document.addEventListener('DOMContentLoaded', updateWishlistBadge);

        function addToCartAjax(productId, qtyOverride, variantId) {
            let qty = qtyOverride || 1;
            let qtyInput = document.getElementById('qtyInput');
            if(!qtyOverride && qtyInput) { qty = qtyInput.value; }
            
            let bodyData = 'productId=' + productId + '&quantity=' + qty;
            if (variantId) {
                bodyData += '&variantId=' + variantId;
            }

            fetch('/Cart/AddToCartAjax', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: bodyData
            })
            .then(response => response.json())
            .then(data => {
                if(data.success) {
                    let badge = document.getElementById('cart-badge');
                    if(badge) badge.innerText = data.cartCount;
                    
                    var cartOffcanvasElement = document.getElementById('cartOffcanvas');
                    if (cartOffcanvasElement && typeof bootstrap !== 'undefined') {
                        var bsOffcanvas = bootstrap.Offcanvas.getInstance(cartOffcanvasElement);
                        if (!bsOffcanvas) {
                            bsOffcanvas = new bootstrap.Offcanvas(cartOffcanvasElement);
                        }
                        fetch('/Cart/GetCartAjax')
                            .then(response => response.text())
                            .then(html => {
                                cartOffcanvasElement.innerHTML = html;
                                bsOffcanvas.show();
                            });
                    }
                    else {
                        Swal.fire({
                            toast: true, position: 'bottom-end', showConfirmButton: false,
                            timer: 3000, timerProgressBar: true, icon: 'success',
                            title: 'Product added to cart successfully 🛒'
                        });
                    }
                }
            });
        }
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

