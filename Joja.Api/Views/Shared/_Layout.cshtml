@using Joja.Api.Data
@using Microsoft.EntityFrameworkCore
@inject ApplicationDbContext _context
@{
    var currentLang = ViewBag.CurrentLanguage ?? "ar";
    var direction = currentLang == "ar" ? "rtl" : "ltr";
    
    // Fetch Settings
    var appSettings = await _context.AppSettings.FirstOrDefaultAsync();
    var fbLink = appSettings?.FacebookLink ?? "#";
    var instaLink = appSettings?.InstagramLink ?? "#";
}
<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - JOJA</title>
    
    <!-- Performance & SEO -->
    <meta name="description" content="JOJA - Natural skincare products for your beauty" />
    <meta name="theme-color" content="#F3E9E2" />
    
    @{
        var pixelId = appSettings?.PixelId;
    }
    @if (!string.IsNullOrEmpty(pixelId))
    {
        <!-- Meta Pixel Code -->
        <script>
        !function(f,b,e,v,n,t,s)
        {if(f.fbq)return;n=f.fbq=function(){n.callMethod?
        n.callMethod.apply(n,arguments):n.queue.push(arguments)};
        if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
        n.queue=[];t=b.createElement(e);t.async=!0;
        t.src=v;s=b.getElementsByTagName(e)[0];
        s.parentNode.insertBefore(t,s)}(window, document,'script',
        'https://connect.facebook.net/en_US/fbevents.js');
        fbq('init', '@pixelId');
        fbq('track', 'PageView');
        </script>
        <noscript><img height="1" width="1" style="display:none"
        src="https://www.facebook.com/tr?id=@pixelId&ev=PageView&noscript=1"
        /></noscript>
        <!-- End Meta Pixel Code -->
    }
    
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @if (currentLang == "ar") {
        <link rel="stylesheet" href="~/css/rtl.css" asp-append-version="true" />
    }
    <link rel="icon" type="image/png" href="~/images/favicon.png" />
    <!-- Add FontAwesome for icons (non-blocking) -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" media="print" onload="this.media='all'">
    <noscript><link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css"></noscript>
</head>
<body>
    <header>
        <!-- Top Bar (Old) -->
        @if (!string.IsNullOrEmpty(appSettings?.TopBarText))
        {
             <div class="top-bar" style="background-color: #B7477E; color: #ffffff; text-align: center; padding: 8px 0; font-size: 0.9rem; font-weight: 500;">
                 <div class="container">
                     @appSettings.TopBarText
                 </div>
             </div>
        }
        
        <!-- Dynamic Header Announcement -->
        @{
            var siteSettingHeader = _context.SiteSettings.FirstOrDefault();
            var headerText = siteSettingHeader?.HeaderAnnouncementText;
        }
        @if (!string.IsNullOrEmpty(headerText))
        {
            <div class="announcement-bar" style="background-color: #B7477E; color: #ffffff; text-align: center; padding: 8px 0; font-weight: bold; font-size: 0.9rem;">
                @headerText
            </div>
        }
        <nav class="navbar">
            <div class="container nav-container">
                <!-- Logo Left -->
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    <img src="~/images/logo.webp" alt="JOJA" class="logo-img" />
                </a>

                <!-- Mobile Menu Toggle -->
                <button class="mobile-menu-toggle" onclick="toggleMobileMenu()">
                    <i class="fas fa-bars"></i>
                </button>

                <!-- Nav Center -->
                <ul class="nav-links" id="navLinks">
                    <li><a asp-controller="Home" asp-action="Index">Home</a></li>
                    <li><a asp-controller="Home" asp-action="Index">Shop</a></li>
                    <li><a asp-controller="Home" asp-action="Index" asp-route-categoryId="2">Hair Care</a></li>
                    <li><a asp-controller="Home" asp-action="Index" asp-route-categoryId="1">Skin Care</a></li>
                    <li><a href="#about-us">About Us</a></li>
                </ul>

                <!-- Icons Right -->
                <div class="nav-icons d-flex align-items-center">
                    <a href="#"><i class="fas fa-search"></i></a>
                    <a href="#"><i class="fas fa-user"></i></a>
                    <a asp-controller="Cart" asp-action="Index" class="nav-link position-relative d-inline-block">
                        <i class="fas fa-shopping-cart" style="font-size: 1.2rem; color: #B7477E;"></i>
                        <span id="cart-badge" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
                            0
                        </span>
                    </a>
                    
                    <!-- Language Switcher -->
                    <div class="language-switcher ms-3 me-3 d-flex align-items-center">
                        @{
                            var currentCulture = System.Threading.Thread.CurrentThread.CurrentUICulture.Name;
                            // إذا لم تكن اللغة الحالية تبدأ بـ ar، إذن نحن في النسخة الإنجليزية (الافتراضية)
                            var isArabic = currentCulture.StartsWith("ar");
                        }
                        
                        @if (isArabic)
                        {
                            <a href="/Home/SetLanguage?culture=en-US&returnUrl=@System.Net.WebUtility.UrlEncode(Context.Request.Path)" class="btn rounded-pill px-3 py-1" style="border: 1px solid #B7477E; color: #B7477E; font-size: 0.9rem; font-weight: bold; text-decoration: none; transition: all 0.3s;" onmouseover="this.style.backgroundColor='#B7477E'; this.style.color='#fff';" onmouseout="this.style.backgroundColor='transparent'; this.style.color='#B7477E';">
                                <i class="fas fa-globe"></i> English
                            </a>
                        }
                        else
                        {
                            <a href="/Home/SetLanguage?culture=ar-EG&returnUrl=@System.Net.WebUtility.UrlEncode(Context.Request.Path)" class="btn rounded-pill px-3 py-1" style="border: 1px solid #B7477E; color: #B7477E; font-size: 0.9rem; font-weight: bold; text-decoration: none; font-family: 'Tajawal', sans-serif; transition: all 0.3s;" onmouseover="this.style.backgroundColor='#B7477E'; this.style.color='#fff';" onmouseout="this.style.backgroundColor='transparent'; this.style.color='#B7477E';">
                                <i class="fas fa-globe"></i> العربية
                            </a>
                        }
                    </div>
                    
                    @if (User.Identity.IsAuthenticated)
                    {
                        <ul class="navbar-nav ms-auto" style="display: flex; flex-direction: row; list-style: none; margin: 0; padding: 0; align-items: center; gap: 15px;">
                            <li class="nav-item">
                                <span class="nav-link text-success" style="font-weight: bold;">Welcome Admin 👑</span>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-warning" asp-controller="Auth" asp-action="ChangePassword" style="font-weight: bold;">Change Password</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-danger" asp-controller="Auth" asp-action="Logout" style="font-weight: bold;">Logout</a>
                            </li>
                        </ul>
                    }
                </div>
            </div>
        </nav>
    </header>

    <script>
        function toggleMobileMenu() {
            document.getElementById('navLinks').classList.toggle('active');
        }
        
        // Close mobile menu when clicking outside
        document.addEventListener('click', function(event) {
            const nav = document.getElementById('navLinks');
            const toggle = document.querySelector('.mobile-menu-toggle');
            if (!nav.contains(event.target) && !toggle.contains(event.target)) {
                nav.classList.remove('active');
            }
        });
    </script>

    <main role="main">
        @RenderBody()
    </main>

    <footer>
        <style>
            footer, footer h3, footer p, footer .copyright { color: #ffffff !important; }
            footer a { color: #ffffff !important; transition: 0.3s; }
            footer a:hover { opacity: 0.8; }
        </style>
        @{
            var siteSettingFooter = _context.SiteSettings.FirstOrDefault();
            var footerText = siteSettingFooter?.FooterAboutText ?? "Natural skincare products formulated with care & science";
        }
        <div class="container">
            <div class="footer-grid">
                <div class="footer-col">
                    <h3>About JOJA</h3>
                    <p>@footerText</p>
                </div>
                <div class="footer-col">
                    <h3>Quick Links</h3>
                    <ul>
                        <li><a href="#">Shop All</a></li>
                        <li><a href="#">Best Sellers</a></li>
                        <li><a href="#">Contact Us</a></li>
                    </ul>
                </div>
                <div class="footer-col">
                    <h3>Follow Us</h3>
                    <div class="social-links">
                        <a href="@fbLink" target="_blank"><i class="fab fa-facebook"></i></a>
                        <a href="@instaLink" target="_blank"><i class="fab fa-instagram"></i></a>
                        <a href="#"><i class="fab fa-tiktok"></i></a>
                    </div>
                    <div style="margin-top: 15px;">
                        <a asp-controller="Admin" asp-action="Index" style="font-size: 0.8rem; opacity: 0.7;">Admin Access</a>
                    </div>
                </div>
            </div>
            <div class="copyright">
                &copy; 2026 JOJA Skincare. All rights reserved.
            </div>
        </div>
    </footer>

    <!-- Newsletter Modal -->
    <div id="newsletterModal" class="joja-modal">
        <div class="modal-content">
            <span class="close-modal" style="position:absolute; right:20px; top:10px; cursor:pointer; font-size:24px;">&times;</span>
            <h2 class="brand-font">Join the Club</h2>
            <p>Subscribe to get exclusive skincare tips and offers.</p>
            <input type="email" id="subscriberEmail" placeholder="Enter your email" />
            <button onclick="submitSubscription()" class="btn-joja-dark">Subscribe</button>
        </div>
    </div>

    @{
        var siteSetting = _context.SiteSettings.FirstOrDefault();
        var whatsappNum = siteSetting?.WhatsAppNumber ?? "201000000000"; 
    }
    <a href="https://wa.me/@whatsappNum" class="whatsapp-float" target="_blank" rel="noopener noreferrer">
        <i class="fab fa-whatsapp"></i>
    </a>

    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        // Modal Logic
        document.addEventListener("DOMContentLoaded", function() {
            // Show modal after 5 seconds if not seen before (and not subscribed)
            if (!localStorage.getItem('joja_popup_seen') && !localStorage.getItem('joja_subscribed')) {
                setTimeout(function() {
                    document.getElementById('newsletterModal').style.display = 'flex';
                }, 5000);
            }

            document.querySelector('.close-modal').onclick = function() {
                document.getElementById('newsletterModal').style.display = 'none';
                // Mark as seen so it doesn't show again
                localStorage.setItem('joja_popup_seen', 'true');
            }
        });

        function submitSubscription() {
            var email = document.getElementById('subscriberEmail').value;
            if(email) {
                fetch('/Home/SubscribeNewsletter', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: 'email=' + encodeURIComponent(email)
                })
                .then(response => response.json())
                .then(data => {
                    if(data.success) {
                        alert(data.message);
                        document.getElementById('newsletterModal').style.display = 'none';
                        localStorage.setItem('joja_subscribed', 'true');
                    }
                });
            }
        }
    </script>
    <script>
        // Analytics Logic
        document.addEventListener("DOMContentLoaded", function() {
            // Track Visit (Once per session)
            if (!sessionStorage.getItem('joja_visit_logged')) {
                fetch('https://ipapi.co/json/')
                    .then(response => response.json())
                    .then(data => {
                        logEvent('Visit', null, data.country_name, data.city);
                        sessionStorage.setItem('joja_visit_logged', 'true');
                    })
                    .catch(() => {
                        logEvent('Visit', null, 'Unknown', 'Unknown');
                        sessionStorage.setItem('joja_visit_logged', 'true');
                    });
            }
        });

        function logEvent(eventType, product = null, country = null, city = null) {
            fetch('/api/Analytics/LogEvent', {
                method: 'POST',
                headers: { 
                    'Content-Type': 'application/json' 
                },
                body: JSON.stringify({
                    eventType: eventType,
                    page: window.location.pathname,
                    product: product,
                    country: country || 'Unknown',
                    city: city || 'Unknown',
                    device: /Mobi|Android/i.test(navigator.userAgent) ? 'Mobile' : 'Desktop'
                })
            }).catch(e => console.error("Analytics Error:", e));
        }
    </script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function addToCartAjax(productId) {
            let qty = 1;
            let qtyInput = document.getElementById('qtyInput');
            if(qtyInput) { qty = qtyInput.value; }
            
            fetch('/Cart/AddToCartAjax', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: 'productId=' + productId + '&quantity=' + qty
            })
            .then(response => response.json())
            .then(data => {
                if(data.success) {
                    let badge = document.getElementById('cart-badge');
                    if(badge) badge.innerText = data.cartCount;
                    
                    Swal.fire({
                        toast: true, position: 'bottom-end', showConfirmButton: false,
                        timer: 3000, timerProgressBar: true, icon: 'success',
                        title: 'Product added to cart successfully 🛒'
                    });
                }
            });
        }
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
