@model Joja.Api.Models.ProductReview

@{
    ViewData["Title"] = "إضافة تقييم جديد";
}

<div class="container mt-4 mb-5">
    <h2>إضافة تقييم (Review) جديد</h2>
    <hr />
    <div class="row">
        <div class="col-md-6">
            <form asp-action="Create">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                
                <div class="form-group mb-3">
                    <label asp-for="ProductId" class="control-label">المنتج (Product)</label>
                    <select asp-for="ProductId" class="form-control" asp-items="ViewBag.ProductId"></select>
                </div>
                
                <div class="form-group mb-3">
                    <label asp-for="UserName" class="control-label">اسم العميل (Customer Name)</label>
                    <input asp-for="UserName" class="form-control" placeholder="مثال: أحمد محمد" required />
                    <span asp-validation-for="UserName" class="text-danger"></span>
                </div>
                
                <div class="form-group mb-3">
                    <label asp-for="Rating" class="control-label">التقييم (Rating 1 - 5)</label>
                    <input asp-for="Rating" class="form-control" type="number" step="0.5" min="1" max="5" value="5" required />
                    <span asp-validation-for="Rating" class="text-danger"></span>
                </div>
                
                <div class="form-group mb-3">
                    <label asp-for="Comment" class="control-label">التعليق (Comment - اختياري)</label>
                    <textarea asp-for="Comment" class="form-control" rows="3" placeholder="تفضل بإضافة رأي العميل هنا..."></textarea>
                    <span asp-validation-for="Comment" class="text-danger"></span>
                </div>
                
                <div class="form-group mt-4">
                    <button type="submit" class="btn btn-success shadow-sm px-4">
                        <i class="fas fa-save"></i> حفظ التقييم
                    </button>
                    <a asp-action="Index" class="btn btn-secondary shadow-sm ms-2">عودة للقائمة</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
