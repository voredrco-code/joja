@model IEnumerable<Joja.Api.Models.ProductReview>

@{
    ViewData["Title"] = "التقييمات (Reviews)";
}

<div class="container mt-4 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>إدارة التقييمات للمنتجات</h2>
        <a asp-action="Create" class="btn btn-success shadow-sm">
            <i class="fas fa-plus"></i> إضافة تقييم جديد
        </a>
    </div>
    <hr />

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover table-striped mb-0 text-center align-middle">
                    <thead class="bg-dark text-white">
                        <tr>
                            <th>المنتج</th>
                            <th>العميل</th>
                            <th>التقييم</th>
                            <th>التعليق</th>
                            <th>التاريخ</th>
                            <th>إجراءات</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    <a href="/Home/Details/@item.ProductId" target="_blank" class="text-decoration-none">
                                        <strong>@item.Product?.Name</strong>
                                    </a>
                                </td>
                                <td>@item.UserName</td>
                                <td>
                                    <span class="badge" style="background-color: #f39c12; font-size: 1rem;">
                                        @item.Rating <i class="fas fa-star"></i>
                                    </span>
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(item.Comment))
                                    {
                                        <span title="@item.Comment">
                                            @(item.Comment.Length > 30 ? item.Comment.Substring(0, 30) + "..." : item.Comment)
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">بدون تعليق</span>
                                    }
                                </td>
                                <td>@item.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                                <td>
                                    <form asp-action="Delete" asp-route-id="@item.Id" method="post" style="display:inline;" onsubmit="return confirm('هل أنت متأكد من حذف هذا التقييم؟');">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-danger shadow-sm">
                                            <i class="fas fa-trash-alt"></i> حذف
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                        
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="6" class="text-center py-4 text-muted">لا توجد تقييمات حتى الآن</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
