@model Joja.Api.Models.Product
@inject Joja.Api.Data.ApplicationDbContext _context
@{
    ViewData["Title"] = Model.Name;
    var language = "en"; // Defaulting to English (Hardcoded for strict compliance)
    var isAr = false;
    var siteSettings = _context.SiteSettings.FirstOrDefault() ?? new Joja.Api.Models.SiteSetting();
}

<div class="container mt-5 mb-5">
    <div class="row">
        <div class="col-12 col-md-6 mb-4">
            <div class="main-image-container" style="border: 1px solid #eaeaea; border-radius: 12px; height: 500px; padding: 20px; background-color: #ffffff; display: flex; align-items: center; justify-content: center;">
                <img id="main-product-image" src="@Model.MainImageUrl" style="max-width: 100%; max-height: 100%; object-fit: contain;" alt="@Model.Name" />
            </div>
            
            @if (Model.GalleryImages != null && Model.GalleryImages.Any())
            {
                <div class="thumbnails-container d-flex gap-2 mt-3" style="overflow-x: auto;">
                    <img src="@Model.MainImageUrl" class="thumbnail-img" onclick="changeMainImage('@Model.MainImageUrl', this)" style="width: 80px; height: 80px; object-fit: contain; border-radius: 8px; cursor: pointer; border: 2px solid #B7477E; padding: 5px; background: #fff;" />
                    @foreach (var img in Model.GalleryImages)
                    {
                        <img src="@img.ImageUrl" class="thumbnail-img" onclick="changeMainImage('@img.ImageUrl', this)" style="width: 80px; height: 80px; object-fit: contain; border-radius: 8px; cursor: pointer; border: 2px solid transparent; padding: 5px; background: #fff;" />
                    }
                </div>
            }
        </div>

        <div class="col-12 col-md-6">
            <h1 style="color: #000; font-weight: 800; font-size: 2.2rem; margin-bottom: 5px;">@Model.Name</h1>
            
            <div class="d-flex align-items-center mb-3">
                <div class="stars" style="color: #f39c12; font-size: 1.2rem; margin-right: 10px;">
                    @for (int i = 1; i <= 5; i++)
                    {
                        if (i <= Model.Rating)
                        {
                            <i class="fas fa-star"></i>
                        }
                        else if (i - 0.5 <= Model.Rating)
                        {
                            <i class="fas fa-star-half-alt"></i>
                        }
                        else
                        {
                            <i class="far fa-star"></i>
                        }
                    }
                </div>
                <span style="color: #777; font-size: 0.95rem;">(@(Model.Rating.ToString("0.0"))) - @Model.ReviewersCount Reviews</span>
            </div>
            
            <div class="price-section mb-4">
                @if (Model.OriginalPrice.HasValue && Model.OriginalPrice > Model.Price)
                {
                    <span style="text-decoration: line-through; color: #a0a0a0; font-size: 1.1rem; margin-right: 10px;">@Model.OriginalPrice.Value EGP</span>
                }
                <span style="color: #B7477E; font-weight: 800; font-size: 1.7rem; text-shadow: 0 0 12px rgba(183, 71, 126, 0.3);">@Model.Price EGP</span>
            </div>

            @if (Model.Variants != null && Model.Variants.Any())
            {
                <div class="product-variants mb-4">
                    <label class="fw-bold mb-2 d-block" style="font-size: 1.1rem; color: #444;">Select Option:</label>
                    <div class="d-flex gap-2 flex-wrap">
                        @foreach (var variant in Model.Variants)
                        {
                            var variantImg = string.IsNullOrEmpty(variant.ImageUrl) ? "" : variant.ImageUrl;
                            <button type="button" class="btn variant-btn d-flex align-items-center gap-2" style="border: 1px solid #ddd; border-radius: 30px; padding: 8px 15px; background: #fff; color: #333; transition: all 0.3s;" data-image="@variantImg" onclick="selectVariant(this)">
                                @if (!string.IsNullOrEmpty(variant.ImageUrl))
                                {
                                    <img src="@variant.ImageUrl" style="width: 30px; height: 30px; border-radius: 50%; object-fit: cover;" />
                                }
                                <span style="font-weight: 600;">@variant.Name</span>
                            </button>
                        }
                    </div>
                </div>
            }

            <div class="d-flex gap-3 mb-4">
                <button type="button" onclick="addToCartAjax(@Model.Id)" class="btn flex-grow-1" style="background-color: #B7477E; color: white; border-radius: 8px; font-weight: bold; padding: 15px; font-size: 1.2rem; border: none; transition: background 0.3s;" onmouseover="this.style.backgroundColor='#9a3b69'" onmouseout="this.style.backgroundColor='#B7477E'">
                    Add to Cart 🛒
                </button>
            </div>

            <div class="product-description mb-4" style="color: #555; line-height: 1.8; font-size: 1.05rem;">
                @{
                    // Force English description, fallback to Description if English is empty
                    var displayDescription = !string.IsNullOrEmpty(Model.DescriptionEn) ? Model.DescriptionEn : Model.Description;
                }
                @Html.Raw(displayDescription)
            </div>

            <div class="accordion" id="productAccordion">
                <div class="accordion-item" style="border: 1px solid #f1f1f1; border-radius: 8px; margin-bottom: 10px; overflow: hidden;">
                    <h2 class="accordion-header" id="headingIngredients">
                        <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#collapseIngredients" aria-expanded="true" aria-controls="collapseIngredients" style="background-color: #f9f9f9; color: #B7477E; font-weight: bold; font-size: 1.1rem;">
                            🌿 Ingredients
                        </button>
                    </h2>
                    <div id="collapseIngredients" class="accordion-collapse collapse show" aria-labelledby="headingIngredients" data-bs-parent="#productAccordion">
                        <div class="accordion-body" style="color: #555; line-height: 1.6;">
                            @(string.IsNullOrEmpty(Model.IngredientsEn) ? (string.IsNullOrEmpty(Model.Ingredients) ? "100% natural and safe ingredients." : Model.Ingredients) : Model.IngredientsEn)
                        </div>
                    </div>
                </div>
                <div class="accordion-item" style="border: 1px solid #f1f1f1; border-radius: 8px; margin-bottom: 10px; overflow: hidden;">
                    <h2 class="accordion-header" id="headingUsage">
                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseUsage" aria-expanded="false" aria-controls="collapseUsage" style="background-color: #f9f9f9; color: #B7477E; font-weight: bold; font-size: 1.1rem;">
                            ✨ Usage Instructions
                        </button>
                    </h2>
                    <div id="collapseUsage" class="accordion-collapse collapse" aria-labelledby="headingUsage" data-bs-parent="#productAccordion">
                        <div class="accordion-body" style="color: #555; line-height: 1.6;">
                            @(string.IsNullOrEmpty(Model.UsageInstructionsEn) ? (string.IsNullOrEmpty(Model.UsageInstructions) ? "Apply gently on the skin." : Model.UsageInstructions) : Model.UsageInstructionsEn)
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>

    <!-- Product Reviews Section -->
    <div class="row mt-5">
        <div class="col-12">
            <!-- Toggle Button -->
            <div class="d-flex align-items-center justify-content-between mb-3" style="border-bottom: 2px solid #eaeaea; padding-bottom: 12px;">
                <h3 style="color: #333; font-weight: 800; font-size: 1.8rem; margin: 0;">
                    Customer Reviews
                    @if (Model.Reviews != null && Model.Reviews.Any())
                    {
                        <span style="font-size: 1rem; color: #B7477E; font-weight: 600; margin-left: 8px;">(@Model.Reviews.Count)</span>
                    }
                </h3>
                <button type="button" id="toggleReviewsBtn" onclick="toggleReviews()" 
                    style="background: #B7477E; color: #fff; border: none; border-radius: 8px; padding: 10px 22px; font-size: 0.95rem; font-weight: 600; cursor: pointer; transition: background 0.3s;"
                    onmouseover="this.style.background='#9a3b69'" onmouseout="this.style.background='#B7477E'">
                    <i class="far fa-comment-dots" id="reviewsIcon"></i>&nbsp; Show Reviews
                </button>
            </div>

            <!-- Collapsible Reviews Container -->
            <div id="reviewsSection" style="display: none; overflow: hidden; transition: all 0.4s ease;">
                @if (Model.Reviews != null && Model.Reviews.Any())
                {
                    <div class="reviews-container" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 20px; margin-bottom: 30px;">
                        @foreach (var review in Model.Reviews.OrderByDescending(r => r.CreatedAt))
                        {
                            <div class="review-card" style="background: #fdfdfd; border: 1px solid #f1f1f1; border-radius: 12px; padding: 20px; box-shadow: 0 4px 10px rgba(0,0,0,0.02);">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <h5 style="margin: 0; font-weight: 700; color: #121212;">@review.UserName</h5>
                                    <div class="stars" style="color: #f39c12; font-size: 0.9rem;">
                                        @for (int i = 1; i <= 5; i++)
                                        {
                                            if (i <= review.Rating)
                                            {
                                                <i class="fas fa-star"></i>
                                            }
                                            else
                                            {
                                                <i class="far fa-star" style="color: #ccc;"></i>
                                            }
                                        }
                                    </div>
                                </div>
                                <small class="text-muted d-block mb-2">@review.CreatedAt.ToString("MMMM dd, yyyy")</small>
                                @if (!string.IsNullOrEmpty(review.Comment))
                                {
                                    <p style="color: #555; line-height: 1.6; font-size: 0.95rem; margin: 0;">"@review.Comment"</p>
                                }
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="text-center p-4 mb-4" style="background: #f9f9f9; border-radius: 12px;">
                        <i class="far fa-comment-dots fa-2x mb-2" style="color: #ccc;"></i>
                        <p style="color: #aaa; margin: 0;">No reviews yet. Be the first!</p>
                    </div>
                }

                <!-- Public Review Submit Form -->
                <div style="background: #fdf2f7; border: 1px solid #f1e0ea; border-radius: 12px; padding: 28px; margin-top: 10px;">
                    <h5 style="color: #B7477E; font-weight: 700; margin-bottom: 20px;">✍️ Write a Review</h5>
                    <form method="post" asp-controller="Home" asp-action="SubmitReview">
                        <input type="hidden" name="productId" value="@Model.Id" />
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label style="font-weight: 600; color: #444; margin-bottom: 6px; display: block;">Your Name</label>
                                <input type="text" name="userName" required 
                                    style="width: 100%; padding: 10px 14px; border: 1px solid #ddd; border-radius: 8px; font-size: 0.95rem; outline: none;"
                                    placeholder="e.g. Sara A." />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label style="font-weight: 600; color: #444; margin-bottom: 6px; display: block;">Rating</label>
                                <div class="star-rating-input d-flex gap-2 align-items-center">
                                    @for (int s = 5; s >= 1; s--)
                                    {
                                        <label style="cursor: pointer; font-size: 1.6rem; color: #ddd; margin: 0;" class="star-label" data-val="@s">&#9733;</label>
                                    }
                                    <input type="hidden" name="rating" id="ratingInput" value="5" />
                                </div>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label style="font-weight: 600; color: #444; margin-bottom: 6px; display: block;">Comment (Optional)</label>
                            <textarea name="comment" rows="3"
                                style="width: 100%; padding: 10px 14px; border: 1px solid #ddd; border-radius: 8px; font-size: 0.95rem; resize: vertical; outline: none;"
                                placeholder="Share your experience with this product..."></textarea>
                        </div>
                        <button type="submit"
                            style="background: #B7477E; color: white; border: none; border-radius: 8px; padding: 12px 30px; font-weight: 700; font-size: 1rem; cursor: pointer; transition: background 0.3s;"
                            onmouseover="this.style.background='#9a3b69'" onmouseout="this.style.background='#B7477E'">
                            Submit Review 🌟
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    function changeMainImage(newSrc, element) {
        if(newSrc) document.getElementById('main-product-image').src = newSrc;
        if(element && element.classList.contains('thumbnail-img')) {
            document.querySelectorAll('.thumbnail-img').forEach(el => el.style.borderColor = 'transparent');
            element.style.borderColor = '#B7477E';
        }
    }
    function selectVariant(button) {
        document.querySelectorAll('.variant-btn').forEach(btn => {
            btn.style.borderColor = '#ddd';
            btn.style.backgroundColor = '#fff';
            btn.style.color = '#333';
        });
        button.style.borderColor = '#B7477E';
        button.style.backgroundColor = '#fdf2f7';
        button.style.color = '#B7477E';

        var newImageUrl = button.getAttribute('data-image');
        if (newImageUrl && newImageUrl.trim() !== '') {
            changeMainImage(newImageUrl, null);
        }
    }

    // === Reviews Toggle ===
    var reviewsOpen = false;
    function toggleReviews() {
        var section = document.getElementById('reviewsSection');
        var btn = document.getElementById('toggleReviewsBtn');
        reviewsOpen = !reviewsOpen;
        if (reviewsOpen) {
            section.style.display = 'block';
            btn.innerHTML = '<i class="fas fa-chevron-up"></i>&nbsp; Hide Reviews';
        } else {
            section.style.display = 'none';
            btn.innerHTML = '<i class="far fa-comment-dots"></i>&nbsp; Show Reviews';
        }
    }

    // === Interactive Star Rating Input ===
    document.addEventListener('DOMContentLoaded', function () {
        var stars = document.querySelectorAll('.star-label');
        var ratingInput = document.getElementById('ratingInput');
        var currentRating = 5;

        function renderStars(val) {
            stars.forEach(function(s) {
                s.style.color = parseInt(s.getAttribute('data-val')) <= val ? '#f39c12' : '#ddd';
            });
        }
        renderStars(currentRating);

        stars.forEach(function(star) {
            star.addEventListener('mouseover', function() {
                renderStars(parseInt(this.getAttribute('data-val')));
            });
            star.addEventListener('mouseout', function() {
                renderStars(currentRating);
            });
            star.addEventListener('click', function() {
                currentRating = parseInt(this.getAttribute('data-val'));
                ratingInput.value = currentRating;
                renderStars(currentRating);
            });
        });
    });
</script>
