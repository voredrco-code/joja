@model Joja.Api.ViewModels.HomeViewModel
@{
    ViewData["Title"] = "Home";
}


<!-- Video Reels Section -->
@if (Model.VideoBanners != null && Model.VideoBanners.Any())
{
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />

    <section class="joja-reels-section">
        <div class="container">
            <h2 class="section-title" style="text-align:center; margin-bottom:30px;">🎬 Joja Reels</h2>
        </div>

        <div class="swiper joja-reels-swiper">
            <div class="swiper-wrapper">
                @foreach (var vid in Model.VideoBanners)
                {
                    <div class="swiper-slide joja-reel-slide">
                        <div class="joja-reel-card">
                            <video class="joja-reel-video" 
                                   loop playsinline 
                                   preload="metadata"
                                   onmouseenter="this.play()"
                                   onmouseleave="this.pause()">
                                <source src="@vid.VideoUrl" type="video/mp4">
                            </video>
                            @if (!string.IsNullOrEmpty(vid.Title))
                            {
                                <div class="joja-reel-caption">@vid.Title</div>
                            }
                        </div>
                    </div>
                }
            </div>

            <div class="swiper-button-prev joja-swiper-prev"></div>
            <div class="swiper-button-next joja-swiper-next"></div>
        </div>
    </section>

    <script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            new Swiper(".joja-reels-swiper", {
                loop: true,
                speed: 600,
                slidesPerView: 1.3,
                spaceBetween: 15,
                centeredSlides: false,
                grabCursor: true,
                autoplay: {
                    delay: 2500,
                    disableOnInteraction: false,
                    pauseOnMouseEnter: true,
                },
                navigation: {
                    nextEl: ".joja-swiper-next",
                    prevEl: ".joja-swiper-prev",
                },
                breakpoints: {
                    576: { slidesPerView: 2.3, spaceBetween: 20 },
                    768: { slidesPerView: 3.3, spaceBetween: 25 },
                    1024: { slidesPerView: 4.3, spaceBetween: 25 },
                }
            });
        });
    </script>
}




<!-- Joja Gallery Strip -->
<div class="joja-gallery-strip-container" style="background-color: #fcfcfc; padding: 40px 0;">
    <h2 class="text-center mb-4" style="color: #B7477E; font-weight: 800; font-size: 2.2rem; font-family: 'Playfair Display', serif; text-transform: uppercase;">✨ Look Premium With Joja Organic</h2>
    
    <div class="video-ticker-container" style="cursor: default;">
        <div class="video-track">
            @foreach (var product in Model.Products)
            {
                if (product.GalleryImages != null && product.GalleryImages.Any()) {
                    foreach (var galleryImg in product.GalleryImages) {
                        <div class="video-item">
                            <img src="@galleryImg.ImageUrl" alt="@product.Name" class="hover-video gallery-strip-img" style="pointer-events: auto;" />
                        </div>
                    }
                } else if (!string.IsNullOrEmpty(product.MainImageUrl)) {
                    <div class="video-item">
                        <img src="@product.MainImageUrl" alt="@product.Name" class="hover-video gallery-strip-img" style="pointer-events: auto;" />
                    </div>
                }
            }
            @foreach (var product in Model.Products)
            {
                if (product.GalleryImages != null && product.GalleryImages.Any()) {
                    foreach (var galleryImg in product.GalleryImages) {
                        <div class="video-item">
                            <img src="@galleryImg.ImageUrl" alt="@product.Name" class="hover-video gallery-strip-img" style="pointer-events: auto;" />
                        </div>
                    }
                } else if (!string.IsNullOrEmpty(product.MainImageUrl)) {
                    <div class="video-item">
                        <img src="@product.MainImageUrl" alt="@product.Name" class="hover-video gallery-strip-img" style="pointer-events: auto;" />
                    </div>
                }
            }
        </div>
    </div>
</div>

<!-- Filter Buttons -->
<div class="container">
    <h2 class="section-title">@(ViewBag.BestSellers ?? "Best Sellers")</h2>
    <div class="filter-buttons filter-list my-4">
        <button class="btn-filter active" onclick="filter(null)">@(ViewBag.FilterAll ?? "All")</button>
        @foreach(var cat in Model.Categories) {
            <button class="btn-filter" onclick="filter(@cat.Id)">@cat.Name</button>
        }
    </div>

    <!-- Product Grid Container -->
    <div id="product-container" class="row mt-4">
        @foreach (var product in Model.Products)
        {
            <partial name="_ProductGrid" model="product" />
        }
    </div>
</div>

<!-- Video Modal -->
<div id="videoModal" class="joja-video-modal" style="display:none;">
    <div class="modal-content-video">
        <span class="close-video" onclick="closeVideo()">&times;</span>
        <video id="modalVideo" controls autoplay muted loop>
            <source src="" type="video/mp4">
        </video>
        <div class="video-info text-center mt-3" style="text-align:center; margin-top:15px;">
            <h3 id="videoProductName" class="brand-font" style="margin-bottom:10px;"></h3>
            <button class="btn-joja-dark px-4 py-2">@(ViewBag.AddToCart ?? "Add to Cart")</button>
        </div>
    </div>
</div>

@section Scripts {
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
    function openVideo(videoUrl, productName) {
        const modal = document.getElementById('videoModal');
        const video = document.getElementById('modalVideo');
        const name = document.getElementById('videoProductName');

        video.src = videoUrl;
        name.innerText = productName;
        
        $(modal).fadeIn(300);
        video.play();
    }

    function closeVideo() {
        const modal = document.getElementById('videoModal');
        const video = document.getElementById('modalVideo');
        
        $(modal).fadeOut(300, function() {
            video.pause();
            video.src = "";
        });
    }

    function filter(catId) {
        $.get("/Home/FilterProducts", { categoryId: catId }, function(data) {
            $("#product-container").html(data);
        });
        // Toggle active class
        $(".btn-filter").removeClass("active");
        event.target.classList.add("active");
    }

    document.addEventListener("DOMContentLoaded", function() {
        // Removed audio handling logic as it's now an image gallery string
    });
</script>
}
