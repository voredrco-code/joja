@model Joja.Api.Models.Product

@{
    ViewData["Title"] = "Edit Product";
}

<style>
    .drag-drop-zone {
        border: 2px dashed #ccc;
        border-radius: 8px;
        padding: 40px;
        text-align: center;
        cursor: pointer;
        transition: border-color 0.3s;
        margin-bottom: 20px;
        background: #f9f9f9;
        position: relative;
    }
    .drag-drop-zone:hover, .drag-drop-zone.dragover {
        border-color: #B7477E;
        background: #fff;
    }
    .variant-card {
        border: 1px solid #ddd;
        padding: 15px;
        border-radius: 8px;
        margin-bottom: 15px;
        background: #fff;
    }
    .variant-header {
        display: flex;
        justify-content: space-between;
        margin-bottom: 10px;
    }
    .desc-textarea {
        resize: vertical;
        min-height: 120px;
    }
</style>

<div class="container" style="margin-top: 50px; margin-bottom: 100px;">
    <h1 class="brand-font">Edit Product: @Model.Name</h1>
    <hr />
    
    <form asp-action="Edit" enctype="multipart/form-data" id="editForm">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="MainImageUrl" />
        <input type="hidden" asp-for="VideoUrl" />
        <!-- Attributes as JSON -->
        <input type="hidden" asp-for="VariantsJson" id="VariantsJson" />

        <div class="row">
            <!-- Left Column: Basic Info -->
            <div class="col-md-6">
                <div class="card p-4 mb-4 shadow-sm">
                    <h4 class="mb-3">Basic Info</h4>
                    
                    <div class="form-group mb-3">
                        <label asp-for="Name" class="control-label"></label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="Description" class="control-label">وصف المنتج (عربي)</label>
                        <textarea asp-for="Description" class="form-control desc-textarea" rows="5"></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="DescriptionEn" class="control-label">Product Description (English)</label>
                        <textarea asp-for="DescriptionEn" class="form-control desc-textarea" rows="5" placeholder="Enter English description here..."></textarea>
                        <span asp-validation-for="DescriptionEn" class="text-danger"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="Price" class="control-label"></label>
                        <input asp-for="Price" class="form-control" type="number" step="0.01" />
                        <span asp-validation-for="Price" class="text-danger"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label class="control-label">السعر قبل الخصم (اختياري)</label>
                        <input asp-for="OriginalPrice" class="form-control" type="number" step="0.01" />
                        <small class="text-muted">اكتب السعر القديم هنا، وسعر البيع الحالي في خانة "السعر". النظام هيحسب نسبة الخصم تلقائياً.</small>
                    </div>

                    <div class="form-group mb-3">
                        <label class="control-label">المكونات</label>
                        <textarea asp-for="Ingredients" class="form-control" rows="3" placeholder="مثال: زيت أرجان نقي، فيتامين E..."></textarea>
                    </div>

                    <div class="form-group mb-3">
                        <label class="control-label">طريقة الاستخدام</label>
                        <textarea asp-for="UsageInstructions" class="form-control" rows="3" placeholder="مثال: ضعي 3 قطرات على بشرة نظيفة..."></textarea>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="IngredientsEn" class="control-label">Ingredients (English)</label>
                        <textarea asp-for="IngredientsEn" class="form-control" rows="3" placeholder="e.g. Pure Argon oil..."></textarea>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="UsageInstructionsEn" class="control-label">Usage Instructions (English)</label>
                        <textarea asp-for="UsageInstructionsEn" class="form-control" rows="3" placeholder="e.g. Apply 3 drops..."></textarea>
                    </div>

                    <div class="row mb-3">
                        <div class="col-6">
                            <label asp-for="Rating" class="control-label">التقييم (Rating)</label>
                            <input asp-for="Rating" class="form-control" type="number" step="0.1" min="0" max="5" />
                        </div>
                        <div class="col-6">
                            <label asp-for="ReviewersCount" class="control-label">عدد المقيمين (Reviewers Count)</label>
                            <input asp-for="ReviewersCount" class="form-control" type="number" step="1" min="0" />
                        </div>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="CategoryId" class="control-label">Category (Optional)</label>
                        <select asp-for="CategoryId" class="form-control" asp-items="@(ViewData["CategoryId"] as SelectList)">
                            <option value="">-- No Category --</option>
                        </select>
                    </div>
                </div>

                <!-- Products Attributes / Variants -->
                <div class="card p-4 mb-4 shadow-sm">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h4 class="mb-0">Product Options (Variants)</h4>
                        <button type="button" class="btn btn-sm btn-outline-primary" onclick="addVariantRow()">+ Add Variant</button>
                    </div>
                    
                    <div id="variantsContainer">
                        @if (Model.Variants != null)
                        {
                            for (int i = 0; i < Model.Variants.Count; i++)
                            {
                                <div class="variant-card bg-light p-3 mb-2 rounded border position-relative">
                                    <button type="button" class="btn btn-sm btn-danger position-absolute" style="top: 10px; right: 10px;" onclick="if(confirm('Delete variant?')) this.parentElement.remove()">X</button>
                                    
                                    <input type="hidden" name="Variants[@i].Id" value="@Model.Variants[i].Id" />
                                    <!-- Keep the existing image URL to avoid overriding it if no new file is uploaded -->
                                    <input type="hidden" name="Variants[@i].ImageUrl" value="@Model.Variants[i].ImageUrl" />
                                    <input type="hidden" name="Variants[@i].ProductId" value="@Model.Variants[i].ProductId" />

                                    <div class="row">
                                        <div class="col-md-4">
                                            <label>Variant Name (e.g. 50ml)</label>
                                            <input type="text" name="Variants[@i].Name" value="@Model.Variants[i].Name" class="form-control form-control-sm" required />
                                        </div>
                                        <div class="col-md-3">
                                            <label>Price Adj. (e.g. +50 or -20)</label>
                                            <input type="number" step="0.01" name="Variants[@i].PriceAdjustment" value="@Model.Variants[i].PriceAdjustment" class="form-control form-control-sm" />
                                        </div>
                                        <div class="col-md-5">
                                            <label>Variant Image (Overrides Main Image)</label>
                                            @if (!string.IsNullOrEmpty(Model.Variants[i].ImageUrl))
                                            {
                                                <div class="mb-1 d-flex align-items-center">
                                                    <img src="@Model.Variants[i].ImageUrl" style="width: 30px; height: 30px; border-radius: 4px; object-fit: cover; margin-right: 5px;" />
                                                    <small class="text-success">Has Image</small>
                                                </div>
                                            }
                                            <input type="file" name="VariantImages" class="form-control form-control-sm" accept="image/*" />
                                            <input type="hidden" name="VariantImageIndices" value="@i" />
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>

            <!-- Right Column: Media -->
            <div class="col-md-6">
                <!-- Image Upload -->
                <div class="card p-4 mb-4 shadow-sm">
                    <h4 class="mb-3">Main Image</h4>
                    @if (!string.IsNullOrEmpty(Model.MainImageUrl))
                    {
                        <img src="@Model.MainImageUrl" class="img-fluid mb-3 rounded" style="max-height: 200px;" />
                        <br />
                    }
                    <label>Change Image</label>
                    <input type="file" name="MainImageFile" class="form-control" accept="image/*" />
                </div>

                <!-- Gallery Upload -->
                <div class="card p-4 mb-4 shadow-sm">
                    <h4 class="mb-3">Gallery Images</h4>
                    <label>Add Additional Images</label>
                    <input type="file" name="galleryFiles" multiple class="form-control" accept="image/*" />
                    <small class="text-muted">You can select multiple images to add to the gallery.</small>
                </div>

                <!-- Video Upload (Drag & Drop) -->
                <div class="card p-4 mb-4 shadow-sm">
                    <h4 class="mb-3">Product Video (Home Page)</h4>
                    @if (!string.IsNullOrEmpty(Model.VideoUrl))
                    {
                        <div class="mb-3">
                            <video src="@Model.VideoUrl" controls style="width: 100%; max-height: 200px; border-radius: 4px;"></video>
                            <p class="small text-muted text-center mt-1">Current Video</p>
                        </div>
                    }

                    <div class="drag-drop-zone" id="videoDropZone">
                        <i class="fas fa-cloud-upload-alt fa-3x" style="color: #ccc;"></i>
                        <p class="mt-2 text-muted">Drag & Drop Video Here<br>or Click to Upload</p>
                        <input type="file" name="VideoFile" id="VideoFile" class="form-control" accept="video/*" style="display:none;" />
                        <p id="videoFileName" class="mt-2 text-success font-weight-bold"></p>
                    </div>
                </div>
            </div>
        </div>

        <div class="fixed-bottom bg-white p-3 border-top shadow text-center">
            <button type="submit" class="btn-joja-dark px-5">Save Changes</button>
            <a asp-action="Index" class="btn btn-secondary ml-3">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
        // --- Variants Logic (New) ---
        let variantIndex = @(Model.Variants?.Count ?? 0);

        function addVariantRow() {
            const container = document.getElementById('variantsContainer');
            const row = document.createElement('div');
            row.className = 'variant-card bg-light p-3 mb-2 rounded border position-relative';
            row.innerHTML = `
                <button type="button" class="btn btn-sm btn-danger position-absolute" style="top: 10px; right: 10px;" onclick="this.parentElement.remove()">X</button>
                <div class="row">
                    <div class="col-md-4">
                        <label>Variant Name (e.g. 50ml)</label>
                        <input type="text" name="Variants[${variantIndex}].Name" class="form-control form-control-sm" required />
                    </div>
                    <div class="col-md-3">
                        <label>Price Adj. (e.g. +50 or -20)</label>
                        <input type="number" step="0.01" name="Variants[${variantIndex}].PriceAdjustment" class="form-control form-control-sm" />
                    </div>
                    <div class="col-md-5">
                        <label>Variant Image (Overrides Main Image)</label>
                        <input type="file" name="VariantImages" data-index="${variantIndex}" class="form-control form-control-sm" accept="image/*" />
                        <!-- Hidden field so we know which index this file belongs to in the backend -->
                        <input type="hidden" name="VariantImageIndices" value="${variantIndex}" />
                    </div>
                </div>
            `;
            container.appendChild(row);
            variantIndex++;
        }
        // Initial render
        renderVariants();
    </script>
}
