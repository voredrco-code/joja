@model Joja.Api.Models.Product

@{
    ViewData["Title"] = "إضافة منتج جديد";
}

<style>
    .desc-textarea {
        resize: vertical;
        min-height: 120px;
    }
</style>

<div class="container mt-4">
    <h2>إضافة منتج لـ Joja</h2>
    <hr />

    <form asp-action="Create" method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()

        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="form-group mb-3">
            <label asp-for="Name" class="control-label">اسم المنتج</label>
            <input asp-for="Name" class="form-control" required />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div class="form-group mb-3">
            <label asp-for="Price" class="control-label">السعر</label>
            <input asp-for="Price" type="number" step="0.01" class="form-control" required />
            <span asp-validation-for="Price" class="text-danger"></span>
        </div>

        <div class="form-group mb-3">
            <label asp-for="CategoryId" class="control-label">التصنيف (اختياري)</label>
            <select asp-for="CategoryId" class="form-control" asp-items="@(ViewData["CategoryId"] as SelectList)">
                <option value="">-- بدون تصنيف --</option>
            </select>
        </div>

        <div class="form-group mb-3">
            <label class="control-label">صورة المنتج</label>
            <input type="file" name="MainImageFile" class="form-control" accept="image/*" />
        </div>

        <div class="form-group mb-3">
            <label>الصور الإضافية (معرض الصور)</label>
            <input type="file" name="AdditionalImages" multiple class="form-control" accept="image/*" />
        </div>

        <div class="form-group mb-3">
            <label asp-for="Description" class="control-label">وصف المنتج (عربي)</label>
            <textarea asp-for="Description" class="form-control desc-textarea" rows="5"></textarea>
        </div>

        <div class="form-group mb-3">
            <label asp-for="DescriptionEn" class="control-label">Product Description (English)</label>
            <textarea asp-for="DescriptionEn" class="form-control desc-textarea" rows="5" placeholder="Enter English description here..."></textarea>
        </div>

        <button type="submit" class="btn btn-primary">حفظ المنتج</button>
        <a asp-action="Index" class="btn btn-secondary">عودة للقائمة</a>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}