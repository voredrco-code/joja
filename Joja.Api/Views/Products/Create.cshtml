@model Joja.Api.Models.Product

@{
    ViewData["Title"] = "إضافة منتج جديد";
}

<style>
    .desc-textarea {
        resize: vertical;
        min-height: 120px;
    }
</style>

<div class="container mt-4">
    <h2>إضافة منتج لـ Joja</h2>
    <hr />

    <form asp-action="Create" method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()

        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="form-group mb-3">
            <label asp-for="Name" class="control-label">اسم المنتج</label>
            <input asp-for="Name" class="form-control" required />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div class="form-group mb-3">
            <label asp-for="Price" class="control-label">السعر</label>
            <input asp-for="Price" type="number" step="0.01" class="form-control" required />
            <span asp-validation-for="Price" class="text-danger"></span>
        </div>

        <div class="form-group mb-3">
            <label class="control-label">السعر قبل الخصم (اختياري)</label>
            <input asp-for="OriginalPrice" class="form-control" type="number" step="0.01" />
            <small class="text-muted">اكتب السعر القديم هنا، وسعر البيع الحالي في خانة "السعر". النظام هيحسب نسبة الخصم تلقائياً.</small>
        </div>

        <div class="form-group mb-3">
            <label class="control-label">المكونات</label>
            <textarea asp-for="Ingredients" class="form-control" rows="3" placeholder="مثال: زيت أرجان نقي، فيتامين E..."></textarea>
        </div>

        <div class="form-group mb-3">
            <label class="control-label">طريقة الاستخدام</label>
            <textarea asp-for="UsageInstructions" class="form-control" rows="3" placeholder="مثال: ضعي 3 قطرات على بشرة نظيفة..."></textarea>
        </div>

        <div class="form-group mb-3">
            <label asp-for="CategoryId" class="control-label">التصنيف (اختياري)</label>
            <select asp-for="CategoryId" class="form-control" asp-items="@(ViewData["CategoryId"] as SelectList)">
                <option value="">-- بدون تصنيف --</option>
            </select>
        </div>

        <div class="form-group mb-3">
            <label class="control-label">صورة المنتج</label>
            <input type="file" name="MainImageFile" class="form-control" accept="image/*" />
        </div>

        <div class="form-group mb-3">
            <label>الصور الإضافية (معرض الصور)</label>
            <input type="file" name="AdditionalImages" multiple class="form-control" accept="image/*" />
        </div>

        <div class="form-group mb-3">
            <label asp-for="Description" class="control-label">وصف المنتج (عربي)</label>
            <textarea asp-for="Description" class="form-control desc-textarea" rows="5"></textarea>
        </div>

        <div class="form-group mb-3">
            <label asp-for="DescriptionEn" class="control-label">Product Description (English)</label>
            <textarea asp-for="DescriptionEn" class="form-control desc-textarea" rows="5" placeholder="Enter English description here..."></textarea>
        </div>

        <div class="card p-4 mb-4 shadow-sm">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h4 class="mb-0">Product Options (Variants)</h4>
                <button type="button" class="btn btn-sm btn-outline-primary" onclick="addVariantRow()">+ Add Variant</button>
            </div>
            <div id="variantsContainer">
            </div>
        </div>

        <button type="submit" class="btn btn-primary px-5">حفظ المنتج</button>
        <a asp-action="Index" class="btn btn-secondary">عودة للقائمة</a>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        let variantIndex = 0;

        function addVariantRow() {
            const container = document.getElementById('variantsContainer');
            const row = document.createElement('div');
            row.className = 'variant-card bg-light p-3 mb-2 rounded border position-relative';
            row.innerHTML = `
                <button type="button" class="btn btn-sm btn-danger position-absolute" style="top: 10px; right: 10px;" onclick="this.parentElement.remove()">X</button>
                <div class="row">
                    <div class="col-md-4">
                        <label>Variant Name (e.g. 50ml)</label>
                        <input type="text" name="Variants[${variantIndex}].Name" class="form-control form-control-sm" required />
                    </div>
                    <div class="col-md-3">
                        <label>Price Adj. (e.g. +50 or -20)</label>
                        <input type="number" step="0.01" name="Variants[${variantIndex}].PriceAdjustment" class="form-control form-control-sm" />
                    </div>
                    <div class="col-md-5">
                        <label>Variant Image (Overrides Main Image)</label>
                        <input type="file" name="VariantImages" class="form-control form-control-sm" accept="image/*" />
                        <input type="hidden" name="VariantImageIndices" value="${variantIndex}" />
                    </div>
                </div>
            `;
            container.appendChild(row);
            variantIndex++;
        }
    </script>
}