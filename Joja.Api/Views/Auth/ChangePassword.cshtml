@{
    ViewData["Title"] = "تغيير كلمة المرور";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-header bg-warning text-dark text-center">
                    <h4>تغيير كلمة المرور</h4>
                </div>
                <div class="card-body">
                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger text-center">@ViewBag.Error</div>
                    }
                    @if (ViewBag.Success != null)
                    {
                        <div class="alert alert-success text-center">@ViewBag.Success</div>
                    }

                    <form asp-controller="Auth" asp-action="ChangePassword" method="post">
                        <div class="form-group mb-3">
                            <label>كلمة المرور الحالية</label>
                            <input type="password" name="currentPassword" class="form-control" required />
                        </div>
                        <div class="form-group mb-3">
                            <label>كلمة المرور الجديدة</label>
                            <input type="password" name="newPassword" class="form-control" required />
                        </div>
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-warning">حفظ الباسورد الجديد</button>
                            <a asp-controller="Products" asp-action="Index" class="btn btn-outline-secondary">الرجوع للمنتجات</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
