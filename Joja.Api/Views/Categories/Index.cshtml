@model IEnumerable<Joja.Api.Models.Category>
@{
    ViewData["Title"] = "إدارة الأقسام";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>📂 إدارة الأقسام</h2>
        <a asp-action="Create" class="btn btn-success">+ إضافة قسم جديد</a>
    </div>

    <div class="table-responsive">
        <table class="table table-bordered table-hover">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>اسم القسم</th>
                    <th>عدد المنتجات</th>
                    <th>الإجراءات</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var cat in Model)
                {
                    <tr>
                        <td>@cat.Id</td>
                        <td>@cat.Name</td>
                        <td>@cat.Products.Count</td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@cat.Id" class="btn btn-sm btn-warning">✏️ تعديل</a>
                            <form asp-action="Delete" asp-route-id="@cat.Id" method="post" style="display:inline;" onsubmit="return confirm('هل أنت متأكد من حذف قسم @cat.Name؟');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-danger">🗑️ حذف</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
