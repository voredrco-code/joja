@model Joja.Api.Models.SiteSetting

@{
    ViewData["Title"] = "إعدادات الموقع - الواتساب";
}

<div class="container-fluid py-4" style="direction: rtl;">
    <h2 class="mb-4 text-success"><i class="fas fa-cog"></i> إعدادات الموقع</h2>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow border-0 rounded-pilled">
        <div class="card-header bg-white border-bottom-0 pb-0">
            <h5 class="mb-0 text-muted"><i class="fab fa-whatsapp text-success"></i> رقم الواتساب العائم</h5>
        </div>
        <div class="card-body">
            <form asp-action="UpdateWhatsApp" method="post">
                <div class="form-group mb-3">
                    <label class="control-label fw-bold">رقم الهاتف (مع كود الدولة، مثال: 201090428764)</label>
                    <input name="whatsAppNumber" class="form-control form-control-lg" value="@Model?.WhatsAppNumber" placeholder="2010..." required />
                    <small class="text-muted">هذا الرقم سيتم استخدامه في زر الواتساب العائم الموجود في جميع صفحات الموقع للتواصل المباشر مع العملاء.</small>
                </div>

                <div class="form-group mb-3 mt-4">
                    <label class="control-label fw-bold">النص الترويجي في الهيدر (Header Announcement)</label>
                    <input name="headerAnnouncementText" class="form-control form-control-lg" value="@Model?.HeaderAnnouncementText" placeholder="Welcome to Joja Organic..." />
                    <small class="text-muted">هذا النص سيظهر في الشريط الإعلاني أعلى الموقع.</small>
                </div>

                <div class="form-group mb-3 mt-4">
                    <label class="control-label fw-bold">نص الفوتر عن المتجر (Footer About Text)</label>
                    <input name="footerAboutText" class="form-control form-control-lg" value="@Model?.FooterAboutText" placeholder="Natural skincare products formulated with care & science" />
                    <small class="text-muted">هذا النص سيظهر في قسم (عن الموقع) في الفوتر أسفل جميع الصفحات.</small>
                </div>
                
                <div class="form-group mb-3 form-check form-switch mt-4">
                    <input class="form-check-input" type="checkbox" role="switch" id="enableStickyCart" name="enableStickyCart" value="true" @(Model?.EnableStickyCart == true ? "checked" : "") style="transform: scale(1.5); margin-left: 10px;">
                    <label class="form-check-label fw-bold" for="enableStickyCart" style="font-size: 1.1rem; margin-right: 25px;">تفعيل الشريط الثابت للسلة (Sticky Cart Bar)</label>
                    <div class="text-muted mt-1" style="font-size: 0.9rem;">عند التفعيل، سيظهر شريط ثابت أسفل الشاشة للمستخدم عند النزول لأسفل في صفحة تفاصيل المنتج، مما يسهل عملية الشراء السريع.</div>
                </div>
                
                <button type="submit" class="btn btn-success btn-lg w-100 mt-3 rounded-pill fw-bold">
                    <i class="fas fa-save"></i> حفظ التعديلات
                </button>
            </form>
        </div>
    </div>
</div>
