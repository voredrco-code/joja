@model IEnumerable<Joja.Api.Models.Banner>

@{
    ViewData["Title"] = "Manage Banners";
    var bannerList = Model.OrderBy(b => b.DisplayOrder).ThenBy(b => b.Id).ToList();
}

<style>
    .order-btns form {
        display: inline;
    }
    .order-btns .btn {
        padding: 2px 8px;
        font-size: 0.8rem;
    }
    .banner-thumb {
        width: 100px;
        height: 56px;
        object-fit: cover;
        border-radius: 4px;
        border: 1px solid #ddd;
    }
    .badge-image  { background-color: #22a06b; color: #fff; padding: 3px 8px; border-radius: 4px; font-size: 0.75rem; }
    .badge-video  { background-color: #0073e6; color: #fff; padding: 3px 8px; border-radius: 4px; font-size: 0.75rem; }
</style>

<div class="container" style="margin-top: 50px;">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="brand-font">Manage Banners</h1>
        <a asp-action="Create" class="btn-joja-dark">Add New Banner</a>
    </div>

    <div class="alert alert-info">
        <i class="fas fa-info-circle"></i>
        Use the <strong>▲ Up</strong> / <strong>▼ Down</strong> buttons to reorder banners.
        Lower <em>Order</em> numbers appear first on the homepage.
    </div>

    <table class="table table-striped table-hover" id="bannersTable">
        <thead>
            <tr>
                <th style="width:60px;">Order</th>
                <th style="width:110px;">Preview</th>
                <th style="width:70px;">Type</th>
                <th>Title</th>
                <th>Subtitle</th>
                <th>Link</th>
                <th style="width:180px;">Actions</th>
            </tr>
        </thead>
        <tbody>
            @for (int i = 0; i < bannerList.Count; i++)
            {
                var item = bannerList[i];
                <tr>
                    <td>
                        <strong>@item.DisplayOrder</strong><br />
                        <span class="order-btns">
                            @if (i > 0)
                            {
                                <form asp-action="MoveUp" asp-route-id="@item.Id" method="post" style="display:inline;">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-secondary" title="Move Up">▲</button>
                                </form>
                            }
                            @if (i < bannerList.Count - 1)
                            {
                                <form asp-action="MoveDown" asp-route-id="@item.Id" method="post" style="display:inline;">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-secondary" title="Move Down">▼</button>
                                </form>
                            }
                        </span>
                    </td>
                    <td>
                        @if (item.BannerType == "Video" && !string.IsNullOrEmpty(item.VideoUrl))
                        {
                            <video src="@item.VideoUrl" class="banner-thumb" muted></video>
                        }
                        else if (!string.IsNullOrEmpty(item.ImageUrl))
                        {
                            <img src="@item.ImageUrl" class="banner-thumb" alt="@item.Title" />
                        }
                        else
                        {
                            <span class="text-muted small">No image</span>
                        }
                    </td>
                    <td>
                        @if (item.BannerType == "Video")
                        {
                            <span class="badge-video">Video</span>
                        }
                        else
                        {
                            <span class="badge-image">Image</span>
                        }
                    </td>
                    <td>@item.Title</td>
                    <td>@item.Subtitle</td>
                    <td><a href="@item.LinkUrl" target="_blank">Link</a></td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" style="display:inline;" onsubmit="return confirm('Delete this banner?');">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <div style="margin-top: 20px;">
        <a asp-controller="Admin" asp-action="Index" class="btn btn-secondary">Back to Dashboard</a>
    </div>
</div>
