@model Joja.Api.Services.CartService
@inject Joja.Api.Services.ILocalizationService _localizationService
@{
    var language = Context.Request.Cookies["UserLanguage"] ?? "en";
    var isAr = language == "ar";
    ViewData["Title"] = isAr ? "Ø³Ù„Ø© Ø§Ù„Ù…Ø´ØªØ±ÙŠØ§Øª" : "Shopping Cart";
}

<div class="container" style="margin-top: 50px;">
    <h1 class="section-title">@(isAr ? "Ø³Ù„Ø© Ø§Ù„Ù…Ø´ØªØ±ÙŠØ§Øª Ø§Ù„Ø®Ø§ØµØ© Ø¨Ùƒ" : "Your Shopping Cart")</h1>

    @if (Model.Items.Count == 0)
    {
        <div style="text-align: center; margin: 50px 0;">
            <p>@(isAr ? "Ø³Ù„ØªÙƒ ÙØ§Ø±ØºØ© Ø­Ø§Ù„ÙŠØ§Ù‹." : "Your cart is empty.")</p>
            <a asp-controller="Home" asp-action="Index" class="btn-primary">@(isAr ? "Ù…ØªØ§Ø¨Ø¹Ø© Ø§Ù„ØªØ³ÙˆÙ‚" : "Continue Shopping")</a>
        </div>
    }
    else
    {
        <div class="cart-table" style="width: 100%; border-collapse: collapse; display: table;">
            <div style="display: table-header-group; font-weight: bold; border-bottom: 2px solid #ddd;">
                <div style="display: table-row;">
                    <div style="display: table-cell; padding: 15px;">@(isAr ? "Ø§Ù„Ù…Ù†ØªØ¬" : "Product")</div>
                    <div style="display: table-cell; padding: 15px;">@(isAr ? "Ø§Ù„Ø³Ø¹Ø±" : "Price")</div>
                    <div style="display: table-cell; padding: 15px;">@(isAr ? "Ø§Ù„ÙƒÙ…ÙŠØ©" : "Quantity")</div>
                    <div style="display: table-cell; padding: 15px;">@(isAr ? "Ø§Ù„Ù…Ø¬Ù…ÙˆØ¹" : "Total")</div>
                    <div style="display: table-cell; padding: 15px;"></div>
                </div>
            </div>
            <div style="display: table-row-group;">
                @foreach (var item in Model.Items)
                {
                    <div style="display: table-row; border-bottom: 1px solid #eee;">
                        <div style="display: table-cell; padding: 15px; vertical-align: middle;">
                            <div style="display: flex; align-items: center;">
                                @{
                                    var displayImage = item.Product.MainImageUrl;
                                    Dictionary<string, string> variants = null;
                                    if (!string.IsNullOrEmpty(item.SelectedVariantsJson))
                                    {
                                        variants = System.Text.Json.JsonSerializer.Deserialize<Dictionary<string, string>>(item.SelectedVariantsJson);
                                        if (variants != null && variants.ContainsKey("_ImageUrl"))
                                        {
                                            displayImage = variants["_ImageUrl"];
                                        }
                                    }
                                }
                                <img src="@displayImage" alt="@item.Product.Name" class="img-fluid" style="width: 50px; height: 50px; object-fit: cover; border-radius: 4px; margin-right: 15px; margin-left: 15px;" />
                                <div>
                                    <div style="font-weight: bold;">@(!isAr && !string.IsNullOrEmpty(item.Product.NameEn) ? item.Product.NameEn : item.Product.Name)</div>
                                    @if (variants != null)
                                    {
                                        var displayVariants = variants.Where(v => v.Key != "_ImageUrl").ToList();
                                        if (displayVariants.Any())
                                        {
                                            <div style="font-size: 0.8rem; color: #666;">
                                                @foreach (var v in displayVariants)
                                                {
                                                    <span>@v.Key: @v.Value</span>@if (v.Key != displayVariants.Last().Key) { <span>, </span> }
                                                }
                                            </div>
                                        }
                                    }
                                </div>
                            </div>
                        </div>
                        <div style="display: table-cell; padding: 15px; vertical-align: middle;">@item.UnitPrice.ToString("0.00") @(isAr ? "Ø¬.Ù…" : "EGP")</div>
                        <div style="display: table-cell; padding: 15px; vertical-align: middle;">@item.Quantity</div>
                        <div style="display: table-cell; padding: 15px; vertical-align: middle;">@((item.UnitPrice * item.Quantity).ToString("0.00")) @(isAr ? "Ø¬.Ù…" : "EGP")</div>
                        <div style="display: table-cell; padding: 15px; vertical-align: middle;">
                            <a asp-action="Remove" asp-route-productId="@item.ProductId" style="color: #B7477E; text-decoration: none; font-size: 0.9rem;">&times; @(isAr ? "Ø­Ø°Ù" : "Remove")</a>
                        </div>
                    </div>
                }
            </div>
        </div>

        <div class="cart-summary" style="margin-top: 30px; text-align: @(isAr ? "right" : "right");">
            <h3>@(isAr ? "Ø§Ù„Ø¥Ø¬Ù…Ø§Ù„ÙŠ:" : "Subtotal:") @Model.Total.ToString("0.00") @(isAr ? "Ø¬.Ù…" : "EGP")</h3>
            <a asp-controller="Checkout" asp-action="Index" class="btn btn-lg mt-3 fw-bold shadow-sm" style="background-color: #B7477E; color: white; border-radius: 8px; font-size: 1.25rem; padding: 12px 35px;">
                @(isAr ? "Ù…ØªØ§Ø¨Ø¹Ø© Ù„Ø¥ØªÙ…Ø§Ù… Ø§Ù„Ø·Ù„Ø¨ ðŸ›’" : "Proceed to Checkout ðŸ›’")
            </a>
        </div>
    }
</div>


